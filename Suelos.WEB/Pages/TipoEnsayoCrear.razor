@page "/tipos-ensayo/crear"
@inject IRepository Repository
@inject NavigationManager NavigationManager

<PageTitle>Crear Tipo de Ensayo</PageTitle>

<h3>Crear Tipo de Ensayo</h3>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}

<EditForm Model="tipoEnsayo" OnValidSubmit="CrearTipoEnsayoAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label">Codigo</label>
        <InputText class="form-control" @bind-Value="tipoEnsayo.Codigo" />
    </div>

    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <InputText class="form-control" @bind-Value="tipoEnsayo.Nombre" />
    </div>

    <div class="mb-3">
        <label class="form-label">Descripcion</label>
        <InputText class="form-control" @bind-Value="tipoEnsayo.Descripcion" />
    </div>

    <div class="form-check mb-3">
        <InputCheckbox class="form-check-input" @bind-Value="tipoEnsayo.Activo" />
        <label class="form-check-label">Activo</label>
    </div>

    <button class="btn btn-primary" type="submit" disabled="@isSaving">Guardar</button>
    <a class="btn btn-secondary ms-2" href="/tipos-ensayo">Cancelar</a>
</EditForm>

@code {
    private readonly TipoEnsayo tipoEnsayo = new()
    {
        Activo = true
    };

    private bool isSaving;
    private string? errorMessage;

    private async Task CrearTipoEnsayoAsync()
    {
        isSaving = true;
        errorMessage = null;

        var response = await Repository.PostAsync("api/tiposensayo", tipoEnsayo);

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isSaving = false;
            return;
        }

        NavigationManager.NavigateTo("/tipos-ensayo");
    }
}
