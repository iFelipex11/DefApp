@page "/muestras"
@inject IRepository Repository
@inject IJSRuntime JSRuntime

<PageTitle>Muestras</PageTitle>

<h3>Muestras</h3>

<p>
    <a class="btn btn-primary" href="/muestras/crear">Nueva muestra</a>
</p>

@if (isLoading)
{
    <p><em>Cargando muestras...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}
else if (muestras.Count == 0)
{
    <p>No hay muestras registradas.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Codigo</th>
                <th>Proyecto</th>
                <th>Punto</th>
                <th>Fecha muestreo</th>
                <th>Fecha recepcion</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var muestra in muestras)
            {
                <tr>
                    <td>@muestra.CodigoMuestra</td>
                    <td>@muestra.PuntoMuestreo?.Proyecto?.Nombre</td>
                    <td>@muestra.PuntoMuestreo?.Codigo</td>
                    <td>@muestra.FechaMuestreo.ToShortDateString()</td>
                    <td>@muestra.FechaRecepcion.ToShortDateString()</td>
                    <td>@muestra.EstadoMuestra</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="@($"/muestras/editar/{muestra.Id}")">Editar</a>
                        <button class="btn btn-sm btn-outline-danger ms-2"
                                @onclick="() => EliminarMuestraAsync(muestra)"
                                disabled="@isDeleting">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Muestra> muestras = [];
    private bool isLoading = true;
    private bool isDeleting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await CargarMuestrasAsync();
    }

    private async Task CargarMuestrasAsync()
    {
        var response = await Repository.GetAsync<List<Muestra>>("api/muestras");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        muestras = response.Response ?? [];
        isLoading = false;
    }

    private async Task EliminarMuestraAsync(Muestra muestra)
    {
        var confirmar = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Se eliminara la muestra '{muestra.CodigoMuestra}'. Deseas continuar?");

        if (!confirmar)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        var response = await Repository.DeleteAsync($"api/muestras/{muestra.Id}");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isDeleting = false;
            return;
        }

        await CargarMuestrasAsync();
        isDeleting = false;
    }
}
