@page "/"
@page "/login"
@attribute [AllowAnonymous]
@layout EmptyLayout
@inject IRepository Repository
@inject ILoginService LoginService
@inject NavigationManager NavigationManager

<PageTitle>Iniciar Sesion</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="card-title mb-3">Iniciar Sesion</h3>
                    <p class="text-muted">Ingresa con tu cuenta para acceder al sistema de suelos.</p>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            @errorMessage
                        </div>
                    }

                    <EditForm Model="loginModel" OnValidSubmit="LoginAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Email</label>
                            <InputText class="form-control" @bind-Value="loginModel.Email" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Contrasena</label>
                            <InputText class="form-control" type="password" @bind-Value="loginModel.Password" />
                        </div>

                        <button class="btn btn-primary w-100" type="submit" disabled="@isSaving">Entrar</button>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly LoginDTO loginModel = new();
    private bool isSaving;
    private string? errorMessage;

    private async Task LoginAsync()
    {
        isSaving = true;
        errorMessage = null;

        var response = await Repository.PostAsync<LoginDTO, TokenDTO>("api/accounts/login", loginModel);

        if (response.Error || response.Response is null)
        {
            errorMessage = response.Error
                ? await response.GetErrorMessageAsync()
                : "No fue posible iniciar sesion.";
            isSaving = false;
            return;
        }

        await LoginService.LoginAsync(response.Response.Token);
        NavigationManager.NavigateTo("/proyectos", true);
    }
}
