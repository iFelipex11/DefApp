@page "/puntos-muestreo"
@inject IRepository Repository
@inject IJSRuntime JSRuntime

<PageTitle>Puntos de Muestreo</PageTitle>

<h3>Puntos de Muestreo</h3>

<p>
    <a class="btn btn-primary" href="/puntos-muestreo/crear">Nuevo punto de muestreo</a>
</p>

@if (isLoading)
{
    <p><em>Cargando puntos de muestreo...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}
else if (puntosMuestreo.Count == 0)
{
    <p>No hay puntos de muestreo registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Codigo</th>
                <th>Proyecto</th>
                <th>Sector</th>
                <th>Descripcion</th>
                <th>Coordenada X</th>
                <th>Coordenada Y</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var punto in puntosMuestreo)
            {
                <tr>
                    <td>@punto.Codigo</td>
                    <td>@punto.Proyecto?.Nombre</td>
                    <td>@punto.Sector</td>
                    <td>@punto.Descripcion</td>
                    <td>@punto.CoordenadaX</td>
                    <td>@punto.CoordenadaY</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="@($"/puntos-muestreo/editar/{punto.Id}")">Editar</a>
                        <button class="btn btn-sm btn-outline-danger ms-2"
                                @onclick="() => EliminarPuntoMuestreoAsync(punto)"
                                disabled="@isDeleting">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<PuntoMuestreo> puntosMuestreo = [];
    private bool isLoading = true;
    private bool isDeleting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await CargarPuntosMuestreoAsync();
    }

    private async Task CargarPuntosMuestreoAsync()
    {
        var response = await Repository.GetAsync<List<PuntoMuestreo>>("api/puntosmuestreo");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        puntosMuestreo = response.Response ?? [];
        isLoading = false;
    }

    private async Task EliminarPuntoMuestreoAsync(PuntoMuestreo puntoMuestreo)
    {
        var confirmar = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Se eliminara el punto de muestreo '{puntoMuestreo.Codigo}'. Deseas continuar?");

        if (!confirmar)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        var response = await Repository.DeleteAsync($"api/puntosmuestreo/{puntoMuestreo.Id}");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isDeleting = false;
            return;
        }

        await CargarPuntosMuestreoAsync();
        isDeleting = false;
    }
}
