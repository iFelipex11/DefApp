@page "/puntos-muestreo/editar/{Id:int}"
@inject IRepository Repository
@inject NavigationManager NavigationManager

<PageTitle>Editar Punto de Muestreo</PageTitle>

<h3>Editar Punto de Muestreo</h3>

@if (isLoading)
{
    <p><em>Cargando punto de muestreo...</em></p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <EditForm Model="puntoMuestreo" OnValidSubmit="GuardarCambiosAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Proyecto</label>
            <InputSelect class="form-select" @bind-Value="puntoMuestreo.ProyectoId">
                <option value="0">Seleccione un proyecto</option>
                @foreach (var proyecto in proyectos)
                {
                    <option value="@proyecto.Id">@proyecto.Nombre</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Codigo</label>
            <InputText class="form-control" @bind-Value="puntoMuestreo.Codigo" />
        </div>

        <div class="mb-3">
            <label class="form-label">Sector</label>
            <InputText class="form-control" @bind-Value="puntoMuestreo.Sector" />
        </div>

        <div class="mb-3">
            <label class="form-label">Descripcion</label>
            <InputText class="form-control" @bind-Value="puntoMuestreo.Descripcion" />
        </div>

        <div class="mb-3">
            <label class="form-label">Coordenada X</label>
            <InputText class="form-control" @bind-Value="puntoMuestreo.CoordenadaX" />
        </div>

        <div class="mb-3">
            <label class="form-label">Coordenada Y</label>
            <InputText class="form-control" @bind-Value="puntoMuestreo.CoordenadaY" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSaving">Guardar cambios</button>
        <a class="btn btn-secondary ms-2" href="/puntos-muestreo">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private PuntoMuestreo puntoMuestreo = new();
    private List<Proyecto> proyectos = [];
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var proyectosResponse = await Repository.GetAsync<List<Proyecto>>("api/proyectos");

        if (proyectosResponse.Error)
        {
            errorMessage = await proyectosResponse.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        proyectos = proyectosResponse.Response ?? [];

        var puntoResponse = await Repository.GetAsync<PuntoMuestreo>($"api/puntosmuestreo/{Id}");

        if (puntoResponse.Error)
        {
            errorMessage = await puntoResponse.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        puntoMuestreo = puntoResponse.Response ?? new PuntoMuestreo();
        isLoading = false;
    }

    private async Task GuardarCambiosAsync()
    {
        if (puntoMuestreo.ProyectoId == 0)
        {
            errorMessage = "Debe seleccionar un proyecto.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        var response = await Repository.PutAsync("api/puntosmuestreo", puntoMuestreo);

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isSaving = false;
            return;
        }

        NavigationManager.NavigateTo("/puntos-muestreo");
    }
}
