@page "/muestras/editar/{Id:int}"
@inject IRepository Repository
@inject NavigationManager NavigationManager

<PageTitle>Editar Muestra</PageTitle>

<h3>Editar Muestra</h3>

@if (isLoading)
{
    <p><em>Cargando muestra...</em></p>
}
else
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger" role="alert">
            @errorMessage
        </div>
    }

    <EditForm Model="muestra" OnValidSubmit="GuardarCambiosAsync">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="mb-3">
            <label class="form-label">Punto de muestreo</label>
            <InputSelect class="form-select" @bind-Value="muestra.PuntoMuestreoId">
                <option value="0">Seleccione un punto de muestreo</option>
                @foreach (var punto in puntosMuestreo)
                {
                    <option value="@punto.Id">@($"{punto.Proyecto?.Nombre} - {punto.Codigo}")</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Codigo de muestra</label>
            <InputText class="form-control" @bind-Value="muestra.CodigoMuestra" />
        </div>

        <div class="mb-3">
            <label class="form-label">Fecha de muestreo</label>
            <InputDate class="form-control" @bind-Value="muestra.FechaMuestreo" />
        </div>

        <div class="mb-3">
            <label class="form-label">Fecha de recepcion</label>
            <InputDate class="form-control" @bind-Value="muestra.FechaRecepcion" />
        </div>

        <div class="mb-3">
            <label class="form-label">Profundidad inicial</label>
            <InputNumber class="form-control" @bind-Value="muestra.ProfundidadInicial" />
        </div>

        <div class="mb-3">
            <label class="form-label">Profundidad final</label>
            <InputNumber class="form-control" @bind-Value="muestra.ProfundidadFinal" />
        </div>

        <div class="mb-3">
            <label class="form-label">Tipo de muestra</label>
            <InputText class="form-control" @bind-Value="muestra.TipoMuestra" />
        </div>

        <div class="mb-3">
            <label class="form-label">Estado</label>
            <InputText class="form-control" @bind-Value="muestra.EstadoMuestra" />
        </div>

        <div class="mb-3">
            <label class="form-label">Observaciones</label>
            <InputText class="form-control" @bind-Value="muestra.Observaciones" />
        </div>

        <button class="btn btn-primary" type="submit" disabled="@isSaving">Guardar cambios</button>
        <a class="btn btn-secondary ms-2" href="/muestras">Cancelar</a>
    </EditForm>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Muestra muestra = new();
    private List<PuntoMuestreo> puntosMuestreo = [];
    private bool isLoading = true;
    private bool isSaving;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var puntosResponse = await Repository.GetAsync<List<PuntoMuestreo>>("api/puntosmuestreo");

        if (puntosResponse.Error)
        {
            errorMessage = await puntosResponse.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        puntosMuestreo = puntosResponse.Response ?? [];

        var muestraResponse = await Repository.GetAsync<Muestra>($"api/muestras/{Id}");

        if (muestraResponse.Error)
        {
            errorMessage = await muestraResponse.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        muestra = muestraResponse.Response ?? new Muestra();
        isLoading = false;
    }

    private async Task GuardarCambiosAsync()
    {
        if (muestra.PuntoMuestreoId == 0)
        {
            errorMessage = "Debe seleccionar un punto de muestreo.";
            return;
        }

        isSaving = true;
        errorMessage = null;

        var response = await Repository.PutAsync("api/muestras", muestra);

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isSaving = false;
            return;
        }

        NavigationManager.NavigateTo("/muestras");
    }
}
