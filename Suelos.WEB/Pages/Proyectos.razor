@page "/proyectos"
@inject IRepository Repository
@inject IJSRuntime JSRuntime

<PageTitle>Proyectos</PageTitle>

<h3>Proyectos</h3>

<p>
    <a class="btn btn-primary" href="/proyectos/crear">Nuevo proyecto</a>
</p>

@if (isLoading)
{
    <p><em>Cargando proyectos...</em></p>
}
else if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
    </div>
}
else if (proyectos.Count == 0)
{
    <p>No hay proyectos registrados.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Cliente</th>
                <th>Ubicacion</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proyecto in proyectos)
            {
                <tr>
                    <td>@proyecto.Nombre</td>
                    <td>@proyecto.Cliente</td>
                    <td>@proyecto.Ubicacion</td>
                    <td>@proyecto.Estado</td>
                    <td>
                        <a class="btn btn-sm btn-outline-primary" href="@($"/proyectos/editar/{proyecto.Id}")">Editar</a>
                        <button class="btn btn-sm btn-outline-danger ms-2"
                                @onclick="() => EliminarProyectoAsync(proyecto)"
                                disabled="@isDeleting">
                            Eliminar
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Proyecto> proyectos = [];
    private bool isLoading = true;
    private bool isDeleting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await CargarProyectosAsync();
    }

    private async Task CargarProyectosAsync()
    {
        var response = await Repository.GetAsync<List<Proyecto>>("api/proyectos");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isLoading = false;
            return;
        }

        proyectos = response.Response ?? [];
        isLoading = false;
    }

    private async Task EliminarProyectoAsync(Proyecto proyecto)
    {
        var confirmar = await JSRuntime.InvokeAsync<bool>(
            "confirm",
            $"Se eliminara el proyecto '{proyecto.Nombre}'. Deseas continuar?");

        if (!confirmar)
        {
            return;
        }

        isDeleting = true;
        errorMessage = null;

        var response = await Repository.DeleteAsync($"api/proyectos/{proyecto.Id}");

        if (response.Error)
        {
            errorMessage = await response.GetErrorMessageAsync();
            isDeleting = false;
            return;
        }

        await CargarProyectosAsync();
        isDeleting = false;
    }
}
